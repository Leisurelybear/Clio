#!/bin/sh
# Pre-commit hook wrapper: locate venv python and delegate to Python script
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || realpath "$(dirname "$0")/..")
for p in "$REPO_ROOT/.venv/Scripts/python.exe" "$REPO_ROOT/.venv/bin/python"; do
    if [ -f "$p" ]; then
        exec "$p" "$REPO_ROOT/.githooks/pre-commit.py"
    fi
done
echo "pre-commit: no venv python found, skipping"
exit 0
