#!/bin/sh
# Pre-commit hook: auto-format Python files with ruff, then re-stage them.

set -e

# Find a Python interpreter that has ruff installed
RUFF=""
for py in ".venv/Scripts/python.exe" ".venv/bin/python" "venv/Scripts/python.exe" "venv/bin/python" "python3" "python"; do
    if $py -m ruff --version >/dev/null 2>&1; then
        RUFF="$py -m ruff"
        break
    fi
done

if [ -z "$RUFF" ]; then
    echo "pre-commit: ruff not found, skipping format"
    exit 0
fi

# Format all files (ruff only touches .py/.pyi files by default)
$RUFF format .

# Re-stage any files that ruff modified
git diff --name-only --diff-filter=M | xargs -r git add
